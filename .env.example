# Faculty Co-Pilot — Environment Configuration Template
# Copy this file to .env (in your Hermes home directory) and fill in real values.
# NEVER commit the real .env file — it contains live credentials.

# =============================================================================
# LLM PROVIDERS
# =============================================================================
DEEPSEEK_API_KEY=your_deepseek_api_key_here
OPENROUTER_API_KEY=your_openrouter_api_key_here

# =============================================================================
# EMAIL (communication channel — IMAP/SMTP)
# =============================================================================
# Use a DEDICATED email address for the bot, never your personal account.
# Gmail: enable 2-Step Verification, then generate an App Password at
# https://myaccount.google.com/apppasswords — use that, not your real password.

EMAIL_ADDRESS=your-bot-address@gmail.com
EMAIL_PASSWORD=your_16_char_app_password_no_spaces
EMAIL_SMTP_HOST=smtp.gmail.com
EMAIL_IMAP_HOST=imap.gmail.com
# Comma-separated list of addresses allowed to message the bot.
# Include the bot's own address AND your real personal address.
EMAIL_ALLOWED_USERS=your-bot-address@gmail.com,your-real-email@gmail.com

# Optional (defaults shown are correct for Gmail, override only if needed)
# EMAIL_SMTP_PORT=587
# EMAIL_IMAP_PORT=993
# EMAIL_POLL_INTERVAL=15

# =============================================================================
# EXTERNAL TOOLS
# =============================================================================
# Free tier at https://newsapi.org/register
NEWS_API_KEY=your_newsapi_key_here
